{
  "name": "timer-counter",
  "version": "0.0.1",
  "scripts": {
    "dfx:start": "dfx start",
    "dev": "vite dev",
    "dev:deploy": "dfx deploy --no-wallet backend_canister && dfx generate backend_canister",
    "build": "vite build && node ./pwa.js",
    "ic:deploy": "dfx deploy --network=ic --no-wallet",
    "test": "vitest",
    "package": "svelte-kit package",
    "preview": "vite preview",
    "prepare": "svelte-kit sync",
    "coverage": "vitest run --coverage",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --ignore-path .gitignore --check . && eslint .",
    "format": "prettier --ignore-path .gitignore --write ."
  },
  "devDependencies": {
    "@dfinity/agent": "^3.4.3",
    "@dfinity/auth-client": "^3.4.3",
    "@dfinity/candid": "^3.4.3",
    "@dfinity/identity": "^3.4.3",
    "@dfinity/principal": "^3.4.3",
    "@eslint/js": "^10.0.1",
    "@noble/curves": "^1.9.2",
    "@noble/hashes": "^1.8.0",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.53.4",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/lodash": "^4.17.24",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "buffer": "^6.0.3",
    "c8": "^11.0.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.0",
    "globals": "^17.4.0",
    "lodash": "^4.17.23",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.53.7",
    "svelte-check": "^4.4.4",
    "svelte-preprocess": "^6.0.3",
    "tailwindcss": "^4.2.1",
    "tslib": "^2.8.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  },
  "type": "module",
  "dependencies": {
    "@xstate/svelte": "^5.0.0",
    "xstate": "^5.28.0"
  }
}