{
  "name": "timer-counter",
  "version": "0.0.1",
  "scripts": {
    "dfx:start": "dfx start",
    "dev": "vite dev",
    "dev:deploy": "dfx deploy --no-wallet backend_canister && dfx generate backend_canister",
    "build": "vite build && node ./pwa.js",
    "ic:deploy": "dfx deploy --network=ic --no-wallet",
    "test": "vitest",
    "package": "svelte-kit package",
    "preview": "vite preview",
    "prepare": "svelte-kit sync",
    "coverage": "vitest run --coverage",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --ignore-path .gitignore --check --plugin-search-dir=. . && eslint --ignore-path .gitignore .",
    "format": "prettier --ignore-path .gitignore --write --plugin-search-dir=. ."
  },
  "devDependencies": {
    "@dfinity/agent": "^3.4.3",
    "@dfinity/auth-client": "^3.4.3",
    "@dfinity/candid": "^3.4.3",
    "@dfinity/identity": "^3.4.3",
    "@dfinity/principal": "^3.4.3",
    "@noble/curves": "^1.9.2",
    "@noble/hashes": "^1.8.0",
    "@sveltejs/adapter-auto": "^3.0.0",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.53.4",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/lodash": "^4.14.182",
    "@typescript-eslint/eslint-plugin": "^5.10.1",
    "@typescript-eslint/parser": "^5.10.1",
    "autoprefixer": "^10.4.4",
    "buffer": "^6.0.3",
    "c8": "^7.11.2",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-svelte3": "^3.2.1",
    "lodash": "^4.17.23",
    "postcss": "^8.4.31",
    "postcss-load-config": "^3.1.4",
    "prettier": "^2.5.1",
    "prettier-plugin-svelte": "^2.5.0",
    "svelte": "^5.53.5",
    "svelte-check": "^4.4.4",
    "svelte-preprocess": "^6.0.3",
    "tailwindcss": "^3.1.3",
    "tslib": "^2.3.1",
    "typescript": "~5.9.3",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18",
    "vite": "^7.0.0"
  },
  "type": "module",
  "dependencies": {
    "@xstate/svelte": "^2.0.0",
    "xstate": "^4.32.0"
  }
}